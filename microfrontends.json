{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    "v0-preliminary-brief-graph": {
      "development": {
        "fallback": "v0-vla.vercel.app"
      }
    },
    "actions-gpt-legal-reasoning-api": {
      "routing": [
        {
          "paths": [
            "/",
            "/api",
            "/api.html",
            "/explorer",
            "/explorer.html",
            "/map",
            "/map.html",
            "/chat",
            "/chat.html",
            "/assets/**",
            "/openapi.json"
          ]
        }
      ]
    },
    "lexpedite-blawx": {
      "routing": [
        {
          "paths": [
            "/kb",
            "/kb/**"
          ]
        }
      ]
    }
  }
}
